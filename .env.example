# =============================================================================
# Jamarr Environment Configuration
# =============================================================================
# Copy this file to .env for development/test or .env.prod for production,
# then fill in your values.
# =============================================================================

# --- Environment ---
# development | production
ENV=development

# --- App networking ---
# IP address the app server binds to inside the container
HOST=0.0.0.0
# IP address of the Docker host (used by UPnP / stream URL generation)
HOST_IP=127.0.0.1
# Port the Jamarr app listens on
HOST_PORT=8111

# --- Database ---
# Credentials for the PostgreSQL container
POSTGRES_USER=jamarr
POSTGRES_PASSWORD=jamarr
POSTGRES_DB=jamarr
# Connection details used by the Jamarr app at runtime
DB_HOST=127.0.0.1
DB_PORT=8110
DB_USER=jamarr
DB_PASS=jamarr
DB_NAME=jamarr
# Interface the Postgres port mapping binds to on the host (127.0.0.1 = localhost only)
DB_LISTEN_ADDR=127.0.0.1

# --- Persistent storage paths ---
# Host directory for PostgreSQL data (production)
DB_DATA_PATH=/path/to/postgres/data
# Host directory for Jamarr cache (scan database, charts, etc.)
CACHE_PATH=/path/to/jamarr/cache

# --- Development overrides ---
# Used by docker-compose.dev.yml — set these if your dev paths differ
DEV_DB_DATA_PATH=/path/to/dev/postgres/data
DEV_CACHE_PATH=/path/to/dev/jamarr/cache

# --- Music volume (NFS) ---
# NFS server address hosting your music library
MUSIC_NFS_ADDR=your-nas-ip
# NFS export path on the server
MUSIC_NFS_PATH=/path/to/music/on/nas
# Writable NFS export used for adaptive stream cache files. By default this
# should be the parent music directory so Jamarr writes to <music>/cache,
# alongside <music>/library. If you pre-create a narrower cache export, set
# this to that export and set JAMARR_STREAM_CACHE_DIR=/app/music-cache.
MUSIC_CACHE_NFS_PATH=/path/to/music/on/nas
# Path inside the container where music is mounted
MUSIC_PATH=/app/music/

# Path inside the container where adaptive transcode cache files are written.
# docker-compose.yml mounts MUSIC_CACHE_NFS_PATH at /app/music-cache.
JAMARR_STREAM_CACHE_DIR=/app/music-cache/cache

# --- Docker Compose ---
# Project name prefix for containers and volumes
COMPOSE_PROJECT_NAME=jamarr

# --- Frontend dev server ---
# URL the Vite dev server uses to reach the backend API
VITE_API_URL=http://127.0.0.1:8111

# --- Test database ---
# Credentials used by docker-compose.test.yml
TEST_DB_USER=jamarr_test
TEST_DB_PASSWORD=jamarr_test
TEST_DB_NAME=jamarr_test

# --- Service API keys ---
# Obtain these from each service's developer portal
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
QOBUZ_APP_ID=your-qobuz-app-id
QOBUZ_SECRET=your-qobuz-secret
QOBUZ_EMAIL=your-qobuz-email
QOBUZ_PASSWORD=your-qobuz-password
TIDAL_CLIENT_ID=your-tidal-client-id
TIDAL_CLIENT_SECRET=your-tidal-client-secret
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_SHARED_SECRET=your-lastfm-shared-secret
FANARTTV_API_KEY=your-fanarttv-api-key

# --- External services ---
PEARLARR_URL=https://your-pearlarr-url
MUSICBRAINZ_ROOT_URL=https://musicbrainz.org

# --- JWT authentication ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=jamarr
JWT_AUDIENCE=jamarr-api
ACCESS_TOKEN_TTL_MINUTES=10
REFRESH_TOKEN_TTL_DAYS=21
# Short-lived token used for streaming audio URLs
STREAM_TOKEN_TTL_SECONDS=300
STREAM_TOKEN_AUDIENCE=jamarr-stream

# --- Session cookies ---
# Set to true in production (requires HTTPS)
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_NAME=jamarr_refresh

# --- Public / reverse-proxy hardening ---
# Comma-separated lists. Leave empty to allow all (development only).
# Include LAN IPs if you access Jamarr directly on the LAN as well as
# through a public nginx hostname.
ALLOWED_HOSTS=
ALLOWED_ORIGINS=
TRUSTED_PROXY_IPS=
